# Required
DATABASE_URL="postgresql://postgres:postgres@db:5432/avieno?schema=public"
JWT_SECRET="replace-with-a-32-plus-character-secret"

# App URLs (recommended for CSRF/origin checks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
AUTH_ORIGIN="http://localhost:3000"

# Optional admin email notifications
ADMIN_EMAIL="admin@example.com"

# Optional WhatsApp CTA
NEXT_PUBLIC_WHATSAPP_NUMBER=""

# Optional SMTP (contact/support email delivery)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@example.com"

# Optional Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_BASE_URL="http://localhost:3000"

# Optional cache-bust for logo
NEXT_PUBLIC_LOGO_VERSION="1"

# Used only for one-time admin creation script (not needed at runtime)
# ADMIN_PASSWORD=""
# ADMIN_NAME="Platform Admin"
